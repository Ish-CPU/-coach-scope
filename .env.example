# --- Database (Neon Postgres) ---
#
# On Vercel, ALWAYS use Neon's pooled connection string (the one with
# `-pooler` in the host) and append `?sslmode=require&pgbouncer=true&connection_limit=1`.
# Each serverless function instance opens its own client; without a pooler
# you hit Postgres `too many connections` errors under modest traffic.
#
# Local dev can use the unpooled URL — it doesn't matter at one machine.
#
#   pooled (Vercel):
#     postgresql://USER:PASS@ep-xxxx-pooler.us-east-2.aws.neon.tech/ratemyu?sslmode=require&pgbouncer=true&connection_limit=1
#   unpooled (migrations / local):
#     postgresql://USER:PASS@ep-xxxx.us-east-2.aws.neon.tech/ratemyu?sslmode=require
#
# Optional: set DIRECT_URL to the unpooled URL so `prisma migrate deploy` can
# get a real connection that supports advisory locks (the pooler can't). To
# use it, also add `directUrl = env("DIRECT_URL")` to the `datasource db`
# block in prisma/schema.prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ratemyu?sslmode=require"
DIRECT_URL=""

# --- NextAuth ---
# In production NEXTAUTH_URL must be the canonical https URL of the deploy.
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Two recurring prices in Stripe — Verified Member.
#   Monthly: $5.99 / month
#   Yearly:  $69.99 / year
STRIPE_PRICE_MONTHLY_ID="price_..."
STRIPE_PRICE_YEARLY_ID="price_..."
# (Optional) legacy fallback — used as the monthly price if STRIPE_PRICE_MONTHLY_ID is unset.
STRIPE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- App ---
# Used in emails + canonical URLs. In production set to the public https URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email (Resend) ---
# Optional: if unset, outbound email silently no-ops. Admin queues + audit
# log still capture everything else.
RESEND_API_KEY=""
EMAIL_FROM="RateMyU <noreply@yourdomain.com>"
# Force a provider override for tests / staging. "resend" | "console"
EMAIL_PROVIDER=""

# --- Admin bootstrap (seed only — not consulted at runtime) ---
MASTER_ADMIN_EMAIL=""
MASTER_ADMIN_PASSWORD=""

# --- AdSense (placeholder, optional) ---
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
