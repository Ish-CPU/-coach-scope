// RateMyU — database schema
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  VIEWER
  VERIFIED_ATHLETE
  VERIFIED_STUDENT
  VERIFIED_PARENT
  ADMIN
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELED
  PAST_DUE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum VerificationStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum VerificationMethod {
  EDU_EMAIL
  ROSTER_LINK
  PROOF_UPLOAD
  PARENT_DOC
}

enum ReviewType {
  COACH
  PROGRAM
  UNIVERSITY
  DORM
  PARENT_INSIGHT
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

enum Division {
  D1
  D2
  D3
  NAIA
  NJCAA
  OTHER
}

// Audience-based group segmentation per spec.
enum GroupType {
  ATHLETE_GROUP
  STUDENT_GROUP
  PARENT_GROUP
}

enum PostStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

// ---------------------------------------------------------------------------
// Auth (NextAuth)
// ---------------------------------------------------------------------------

model User {
  id                   String             @id @default(cuid())
  name                 String?
  email                String             @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  role                 UserRole           @default(VIEWER)
  // Two-layer model:
  //   paymentVerified   = true once Stripe confirms an active subscription
  //   subscriptionStatus = lifecycle state from Stripe (FREE/ACTIVE/CANCELED/PAST_DUE)
  //   verificationStatus = role-verification outcome (NONE/PENDING/VERIFIED/REJECTED)
  paymentVerified      Boolean            @default(false)
  subscriptionStatus   SubscriptionStatus @default(FREE)
  verificationStatus   VerificationStatus @default(NONE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  bio                  String?
  schoolId             String?
  sport                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts             Account[]
  sessions             Session[]
  reviews              Review[]
  helpfulVotes         HelpfulVote[]
  reports              Report[]           @relation("Reporter")
  favorites            Favorite[]
  verificationRequests VerificationRequest[]
  emailCodes           EmailVerificationCode[]
  subscription         Subscription?

  // Groups
  groupMemberships     GroupMembership[]
  groupsCreated        Group[]            @relation("GroupCreator")
  groupPosts           GroupPost[]
  groupComments        GroupComment[]
  postVotes            GroupPostVote[]
  commentVotes         GroupCommentVote[]

  @@index([role])
  @@index([subscriptionStatus])
  @@index([verificationStatus])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Stripe / billing
// ---------------------------------------------------------------------------

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  interval             BillingInterval    @default(MONTHLY)
  status               SubscriptionStatus @default(FREE)
  // Role the user picked at checkout — copied through Stripe metadata so
  // the webhook can hydrate User.role on activation without depending on
  // a fragile in-memory state.
  selectedRole         UserRole?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Schools / Programs / Coaches / Universities / Dorms
// ---------------------------------------------------------------------------

model School {
  id              String    @id @default(cuid())
  universityId    String
  sport           String
  division        Division  @default(D1)
  conference      String?
  description     String?

  // Public-data source tracking
  athleticsUrl    String?
  sourceUrl       String?
  sourceName      String?
  seasonYear      String?
  lastVerifiedAt  DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  coaches    Coach[]
  reviews    Review[]
  favorites  Favorite[]
  groups     Group[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, sport])
  @@index([sport])
  @@index([division])
}

model Coach {
  id        String   @id @default(cuid())
  name      String
  title     String?
  schoolId  String
  bio       String?
  imageUrl  String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  reviews   Review[]
  favorites Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([name])
}

model University {
  id          String   @id @default(cuid())
  name        String   @unique
  city        String?
  state       String?
  description String?
  imageUrl    String?
  websiteUrl  String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  schools    School[]
  dorms      Dorm[]
  diningHalls Dining[]
  facilities  Facility[]
  reviews    Review[]
  favorites  Favorite[]
  groups     Group[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
}

model Dorm {
  id           String   @id @default(cuid())
  name         String
  universityId String
  description  String?
  imageUrl     String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  reviews    Review[]
  favorites  Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, name])
}

// Public dining locations on campus (factual directory data only).
model Dining {
  id           String   @id @default(cuid())
  name         String
  universityId String
  location     String?
  hours        String?
  description  String?
  imageUrl     String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, name])
}

// Public athletic facilities (stadiums, weight rooms, training centers, etc.).
model Facility {
  id           String   @id @default(cuid())
  name         String
  universityId String
  // Optional sport tag — if set, must match an allowed Sport in src/lib/sports.ts.
  sport        String?
  facilityType String?  // e.g. "Stadium", "Practice Facility", "Weight Room"
  description  String?
  imageUrl     String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, name])
  @@index([sport])
}

// ---------------------------------------------------------------------------
// Reviews / Ratings
// ---------------------------------------------------------------------------

model Review {
  id           String       @id @default(cuid())
  authorId     String
  reviewType   ReviewType
  status       ReviewStatus @default(PUBLISHED)

  coachId      String?
  schoolId     String?
  universityId String?
  dormId       String?

  title        String?
  body         String       @db.Text

  ratings      Json
  overall      Float

  // pre-computed weight at submission time
  // (Athlete=2.0, Parent=1.25, Student=1.25)
  weight       Float        @default(1.0)

  helpfulCount Int          @default(0)
  reportCount  Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  coach        Coach?       @relation(fields: [coachId], references: [id], onDelete: Cascade)
  school       School?      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  university   University?  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  dorm         Dorm?        @relation(fields: [dormId], references: [id], onDelete: Cascade)

  helpfulVotes HelpfulVote[]
  reports      Report[]

  @@index([reviewType, status, createdAt])
  @@index([coachId])
  @@index([schoolId])
  @@index([universityId])
  @@index([dormId])
  @@index([authorId])
}

model Rating {
  id         String     @id @default(cuid())
  reviewType ReviewType
  targetId   String
  category   String
  avg        Float
  count      Int

  updatedAt DateTime @updatedAt

  @@unique([reviewType, targetId, category])
  @@index([targetId])
}

model HelpfulVote {
  id       String @id @default(cuid())
  userId   String
  reviewId String

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
}

model Favorite {
  id           String      @id @default(cuid())
  userId       String
  coachId      String?
  schoolId     String?
  universityId String?
  dormId       String?

  createdAt DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coach      Coach?      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  school     School?     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id], onDelete: Cascade)
  dorm       Dorm?       @relation(fields: [dormId], references: [id], onDelete: Cascade)

  @@unique([userId, coachId])
  @@unique([userId, schoolId])
  @@unique([userId, universityId])
  @@unique([userId, dormId])
}

// ---------------------------------------------------------------------------
// Trust & safety
// ---------------------------------------------------------------------------

model Report {
  id         String       @id @default(cuid())
  reporterId String
  reviewId   String?
  postId     String?
  commentId  String?
  reason     String
  details    String?      @db.Text
  status     ReportStatus @default(OPEN)

  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  reporter User           @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  review   Review?        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  post     GroupPost?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment  GroupComment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reviewId])
  @@index([postId])
}

model VerificationRequest {
  id              String              @id @default(cuid())
  userId          String
  // Which role this verification is targeting — copied off the user at submit
  // time so admins know what to validate against, even if the user's role is
  // somehow changed later.
  targetRole      UserRole
  method          VerificationMethod
  // For parent flows, this stays true; we keep it for analytics/back-compat.
  isParentRequest Boolean             @default(false)
  eduEmail        String?
  rosterUrl       String?
  proofUrl        String?
  notes           String?             @db.Text
  status          VerificationStatus  @default(PENDING)

  reviewedAt DateTime?
  reviewedBy String?

  // Anti-fake counter — bumped on each retry by this same user.
  attemptNumber  Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
}

// One-time email codes used by the student/parent verification flows.
model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  purpose   String   // e.g. "STUDENT_EDU", "PARENT_EMAIL"
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Verified Groups (Reddit-style, audience-segmented)
// ---------------------------------------------------------------------------

model Group {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  description  String?    @db.Text
  // Audience that owns the group — only members of the matching role can post.
  groupType    GroupType
  // Optional ties to a university / sport / school for topic flavor.
  universityId String?
  schoolId     String?
  sport        String?
  isPrivate    Boolean    @default(false)

  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  creator      User             @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  university   University?      @relation(fields: [universityId], references: [id], onDelete: SetNull)
  school       School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  members      GroupMembership[]
  posts        GroupPost[]

  @@index([groupType])
  @@index([universityId])
  @@index([sport])
}

model GroupMembership {
  id       String  @id @default(cuid())
  userId   String
  groupId  String
  isAdmin  Boolean @default(false)

  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model GroupPost {
  id            String     @id @default(cuid())
  groupId       String
  authorId      String
  title         String
  body          String     @db.Text
  status        PostStatus @default(PUBLISHED)

  upvoteCount   Int        @default(0)
  downvoteCount Int        @default(0)
  totalScore    Int        @default(0)
  commentCount  Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group    Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes    GroupPostVote[]
  comments GroupComment[]
  reports  Report[]

  @@index([groupId, createdAt])
  @@index([groupId, totalScore])
  @@index([authorId])
}

model GroupComment {
  id       String     @id @default(cuid())
  postId   String
  authorId String
  parentId String?
  body     String     @db.Text
  status   PostStatus @default(PUBLISHED)

  upvoteCount   Int @default(0)
  downvoteCount Int @default(0)
  totalScore    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    GroupPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  GroupComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies GroupComment[]     @relation("CommentReplies")
  votes   GroupCommentVote[]
  reports Report[]

  @@index([postId, createdAt])
  @@index([parentId])
}

model GroupPostVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  value     Int      // +1 or -1
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model GroupCommentVote {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comment GroupComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}
