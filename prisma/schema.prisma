// MyUniversityVerified — database schema
// PostgreSQL + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  VIEWER
  VERIFIED_ATHLETE
  // Former college athlete. Same access surface as VERIFIED_ATHLETE so they
  // can review coaches/programs/universities/dorms, but reviews are weighted
  // slightly lower (REVIEW_WEIGHTS.VERIFIED_ATHLETE_ALUMNI) and rendered with
  // a distinct badge so readers can tell current from alumni perspectives.
  VERIFIED_ATHLETE_ALUMNI
  // Prospective athlete being recruited but not yet on a roster. EXCLUSIVELY
  // permitted to write RECRUITING reviews against schools that recruited
  // them (verified by structured proof — official visit, camp invite,
  // staff DM, recruiting questionnaire, offer letter, recruiting profile
  // link). Cannot review coaches, programs, universities, dorms, or
  // student-life — they haven't actually attended. When they commit /
  // walk on / enroll they upgrade to VERIFIED_ATHLETE through the regular
  // verification flow and inherit full athlete-trusted access.
  VERIFIED_RECRUIT
  VERIFIED_STUDENT
  // Former student. Same access surface as VERIFIED_STUDENT — can review
  // universities, dorms, and campus life — but reviews are weighted slightly
  // lower (REVIEW_WEIGHTS.VERIFIED_STUDENT_ALUMNI) and render with a distinct
  // badge so readers can tell current from former students apart.
  VERIFIED_STUDENT_ALUMNI
  VERIFIED_PARENT
  // Staff admin — moderates the queues the master admin gives them access
  // to via `User.adminPermissions`. Cannot create/disable other admins,
  // cannot change owner-level settings, cannot manage MASTER_ADMIN rows.
  ADMIN
  // Owner / creator. Exactly one of these is expected per deployment
  // (created via scripts/create-master-admin.ts). Implicitly has every
  // admin permission and is the only role that can manage other admins
  // and edit the recovery-email list.
  MASTER_ADMIN
}

// Lifecycle of an admin/staff account. Stored on User.adminStatus and is
// non-null only for ADMIN / MASTER_ADMIN rows. Drives the team list UI,
// gates sign-in, and zeroes permissions for any non-ACTIVE state.
//
// State transitions are master-admin only:
//   INVITED → ACTIVE        (after onboarding)
//   ACTIVE  → DISABLED      (hard-stop, requires reactivation to return)
//   ACTIVE  → SUSPENDED     (temporary block while master investigates)
//   ACTIVE  → REMOVED       (former admin; row preserved for history)
//   DISABLED/SUSPENDED → ACTIVE (reactivate)
//   anything → REMOVED      (terminal soft-archive — keeps audit history)
enum AdminStatus {
  // Created via the team page but the user hasn't accepted their invite
  // (set their password / accepted the admin rules) yet.
  INVITED
  // Live admin account.
  ACTIVE
  // Hard-disabled by the master admin. Sign-in is rejected and every
  // permission check returns false. Master can reactivate.
  DISABLED
  // Temporarily blocked pending review (e.g. master is investigating an
  // incident). Same access surface as DISABLED — no sign-in, zero perms —
  // but rendered separately in the team UI so the "this is temporary"
  // signal is obvious.
  SUSPENDED
  // Terminal soft-archive. The user row stays so audit logs and historical
  // approvals (`reviewedBy`) keep their actor reference, but they cannot
  // sign in or hold any permission. Always paired with a removalReason.
  REMOVED
}

// Why a master admin removed/disabled/suspended a staff admin. Free-form
// custom notes live alongside this on User.removalNote. Optional — set on
// the same PATCH that flips adminStatus into a blocking state.
enum AdminRemovalReason {
  QUIT
  TERMINATED
  INACTIVITY
  POLICY_VIOLATION
  TEMPORARY_SUSPENSION
  OTHER
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELED
  PAST_DUE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum VerificationStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

// Per-request lifecycle for VerificationRequest. Distinct from User.verificationStatus
// (which stays NONE/PENDING/VERIFIED/REJECTED for downstream gates).
//
// At submit time the auto-confidence scorer (src/lib/verification-confidence.ts)
// stamps one of HIGH_CONFIDENCE / NEEDS_REVIEW / LOW_CONFIDENCE based on the
// evidence the user provided. Admins re-sort the queue by that score so
// obviously-real submissions can be approved fast and dubious ones get
// human eyes. Admin actions move the row to APPROVED, REJECTED, or
// NEEDS_MORE_INFO (which kicks the row back to the user with a note).
//
// PENDING is reserved for the moment between "row inserted" and "score
// computed" — in practice the API computes the score in the same
// transaction so this state is rarely seen.
enum VerificationRequestStatus {
  PENDING
  HIGH_CONFIDENCE
  NEEDS_REVIEW
  LOW_CONFIDENCE
  NEEDS_MORE_INFO
  APPROVED
  REJECTED
}

enum VerificationMethod {
  EDU_EMAIL
  ROSTER_LINK
  PROOF_UPLOAD
  PARENT_DOC
}

enum ReviewType {
  COACH
  PROGRAM
  UNIVERSITY
  DORM
  PARENT_INSIGHT
  // Recruiting review — submitted by athletes who were RECRUITED_BY a program
  // but did not necessarily play for it. Targets a school (program), rates the
  // recruiting process. The form may name a specific recruiter/coach, but the
  // structured ratings are about the program/process — not a coach attack.
  RECRUITING
  // Admissions / campus-visit review — submitted by students who applied or
  // visited but did not enroll. Targets a university, rates the admissions
  // process / campus visit experience. Same idea as RECRUITING, but for the
  // student side.
  ADMISSIONS
}

// How an athlete is connected to a school's program. Drives every per-target
// permission check at review-submit time. A user may have multiple
// connections (e.g. RECRUITED_BY school X, then COMMITTED to / TRANSFERRED_FROM
// Y, then ATHLETE_ALUMNI of Z). Each connection is independently reviewable
// by an admin.
enum AthleteConnectionType {
  CURRENT_ATHLETE
  ATHLETE_ALUMNI
  RECRUITED_BY
  TRANSFERRED_FROM
  COMMITTED
  WALK_ON
}

enum AthleteConnectionStatus {
  PENDING
  APPROVED
  REJECTED
}

// Mirrors AthleteConnectionType but for students. CURRENT_STUDENT and
// STUDENT_ALUMNI unlock university/dorm reviews; ADMITTED_TO and
// VISITED_CAMPUS unlock ADMISSIONS reviews only.
enum StudentConnectionType {
  CURRENT_STUDENT
  STUDENT_ALUMNI
  ADMITTED_TO
  TRANSFERRED_FROM
  VISITED_CAMPUS
}

enum StudentConnectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

// Moderation outcome for a single Review row. Distinct from `ReviewStatus`
// (which is the publishing state set by admin moderation actions on
// reports). New rows are auto-classified by src/lib/review-risk.ts at
// submit time:
//   PUBLISHED      — low risk, visible immediately (default)
//   PENDING_REVIEW — medium risk, hidden from public reads until admin
//                    approves; user sees "pending moderation" message
//   FLAGGED        — high risk OR contains harassment, hidden from
//                    public reads, surfaced as a priority queue item,
//                    fires a moderation alert email
//   REMOVED        — admin-removed (terminal). Mirrors ReviewStatus.REMOVED
//                    so downstream filters can branch on either column.
enum ReviewModerationStatus {
  PUBLISHED
  PENDING_REVIEW
  FLAGGED
  REMOVED
}

enum Division {
  D1
  D2
  D3
  NAIA
  NJCAA
  OTHER
}

// Lifecycle for athlete-submitted "my school/program isn't here" requests.
// PENDING       — fresh submission, awaiting admin triage
// NEEDS_REVIEW  — admin flagged for follow-up (missing info, suspect data)
// APPROVED      — admin imported the school/program; request is closed
// REJECTED      — admin rejected (duplicate, fake school, off-platform sport)
enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVIEW
}

// Audience-based group segmentation per spec.
// Two generations of group taxonomy live side by side, intentionally:
//   - Audience types (ATHLETE_GROUP / STUDENT_GROUP / PARENT_GROUP) — the
//     original audience-segmented model used by `canParticipateInGroup`
//     and the legacy /groups landing. Kept so existing rows stay valid.
//   - Entity types (UNIVERSITY / PROGRAM / COACH / PARENT / RECRUITING) —
//     the new entity-anchored taxonomy. Each row points at a real
//     University / School / Coach via the corresponding nullable FK.
//
// New seeded + user-created groups should prefer entity types. The
// landing page renders entity types under their own sections; legacy
// audience types fall through to a generic "Audience communities"
// bucket so they're never lost.
enum GroupType {
  ATHLETE_GROUP
  STUDENT_GROUP
  PARENT_GROUP
  UNIVERSITY
  PROGRAM
  COACH
  PARENT
  RECRUITING
}

// Visibility supersedes the legacy `Group.isPrivate` boolean. The boolean
// stays on the model for back-compat reads but new code reads `visibility`.
//   PUBLIC        — anyone (signed-in or not) can view
//   VERIFIED_ONLY — sign-in + role-verified required to view + post
//   PRIVATE       — visible only to current members + admins
enum GroupVisibility {
  PUBLIC
  VERIFIED_ONLY
  PRIVATE
}

// Lifecycle-audience gate, orthogonal to GroupAccessMode.
//   CURRENT_ONLY        — only users whose lifecycle is "current" (not isAlumni)
//                         can view + post. Use for active-roster team rooms.
//   ALUMNI_ONLY         — only users with isAlumni=true can view + post.
//                         Use for alumni mentorship + transfer-portal alumni rooms.
//   CURRENT_AND_ALUMNI  — default. Both current and alumni in the relevant
//                         role bucket can view + post. The historical default
//                         so legacy groups keep working unchanged.
//
// Permission gate is enforced in src/lib/permissions.ts (canViewGroup /
// canPostInGroup). Admin / master admin bypass this gate.
enum LifecycleAudience {
  CURRENT_ONLY
  ALUMNI_ONLY
  CURRENT_AND_ALUMNI
}

// Group access + posting mode — supersedes `Group.visibility` for new
// rows. Splits "who can view" from "who can post" so a public-readable
// recruiting group can still gate posts to verified accounts. The legacy
// `visibility` enum stays on the model for older rows; new code reads
// `accessMode`.
enum GroupAccessMode {
  PUBLIC_VIEW_PUBLIC_POST    // anyone reads; anyone signed-in posts
  PUBLIC_VIEW_VERIFIED_POST  // anyone reads; only verified accounts post
  VERIFIED_ONLY              // verified accounts only — read AND post
  PRIVATE                    // members-only — read AND post
}

// GroupMembership.role replaces the legacy `isAdmin` boolean. Three tiers:
//   MEMBER     — vanilla member; can post / comment / vote
//   MODERATOR  — group-scoped moderator (master admin appoints); can pin
//                / lock / remove posts and review reports for THIS group
//   ADMIN      — group owner (the user who created the group via the
//                team form). Same powers as MODERATOR plus moderator
//                assignment within the group.
enum GroupMembershipRole {
  MEMBER
  MODERATOR
  ADMIN
}

// Tag taxonomy for group posts. Stored as a Postgres enum array on
// GroupPost.tags so a single post can carry multiple tags (e.g. a
// recruiting + transfer-portal question). Add new values at the end —
// removing a value is a breaking schema change.
enum GroupPostTag {
  RECRUITING
  TRANSFER_PORTAL
  NIL
  FACILITIES
  PLAYING_TIME
  TEAM_CULTURE
  DORM_LIFE
  PARENT_QUESTION
  COACH_QUESTION
}

// In-app notification taxonomy. Free-form `data Json` on the row carries
// the per-type payload (post id, vote count, mod action label, etc.).
enum NotificationType {
  REPLY_TO_POST
  REPLY_TO_COMMENT
  POST_UPVOTE
  MOD_ACTION
  ADMIN_ACTION
  GROUP_INVITE
  GROUP_APPROVAL
}

enum PostStatus {
  PUBLISHED
  HIDDEN
  REMOVED
}

// ---------------------------------------------------------------------------
// Auth (NextAuth)
// ---------------------------------------------------------------------------

model User {
  id                   String             @id @default(cuid())
  name                 String?
  email                String             @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  role                 UserRole           @default(VIEWER)
  // Two-layer model:
  //   paymentVerified   = true once Stripe confirms an active subscription
  //   subscriptionStatus = lifecycle state from Stripe (FREE/ACTIVE/CANCELED/PAST_DUE)
  //   verificationStatus = role-verification outcome (NONE/PENDING/VERIFIED/REJECTED)
  paymentVerified      Boolean            @default(false)
  subscriptionStatus   SubscriptionStatus @default(FREE)
  verificationStatus   VerificationStatus @default(NONE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  bio                  String?
  schoolId             String?
  sport                String?

  // --- Lifecycle (alumni-aware) ---------------------------------------------
  // Alumni status is orthogonal to `role`. A VERIFIED_ATHLETE with
  // isAlumni=true is a former athlete who keeps their athlete-grade review
  // weight and group access; we just render the badge differently and gate
  // CURRENT_ONLY groups against them. The legacy *_ALUMNI roles still exist
  // for back-compat (and for rows promoted before this flag landed) — the
  // backfill script syncs them to isAlumni=true.
  //
  // formerUniversityId / formerProgramId hold the school/program a user
  // transferred OUT of (or graduated from). They do not replace the existing
  // AthleteProgramConnection / StudentUniversityConnection rows; those remain
  // the source of truth for "every connection this user has ever had". These
  // two fields are a cheap denormalized pointer for profile rendering +
  // search filtering ("Former Players of Coach X") without joining through
  // the connection tables on every read.
  //
  // graduationYear / lastRosterSeason carry the "when" — graduation year for
  // students, last competitive season for athletes. Both nullable; UI shows
  // whichever is set.
  isAlumni             Boolean            @default(false)
  alumniSince          DateTime?
  formerUniversityId   String?
  formerProgramId      String?
  graduationYear       Int?
  lastRosterSeason     Int?

  // --- Admin / master-admin fields (null for normal users) ---
  // Lifecycle state. Set when the user is promoted/created as an admin.
  adminStatus          AdminStatus?
  // JSON object of granular permission flags. See src/lib/admin-permissions.ts
  // for the canonical shape. Master admins ignore this — they're implicitly
  // all-true. Storing as Json keeps the schema flexible while we iterate.
  adminPermissions     Json?
  // Work email distinct from the primary login email (which is `email`).
  // Master admin captures this on the team form so personal/work addresses
  // can stay separate even when the login email is the work one.
  workEmail            String?
  // Updated on every successful credentials sign-in. Surfaced on the team
  // list so master admin can see who's stale.
  lastLoginAt          DateTime?
  // Set the first time an admin completes the onboarding flow
  // (/admin/onboarding) — accepting the admin rules. Until non-null we
  // route admins through onboarding on every admin page hit. Kept as the
  // canonical timestamp; `onboardingCompleted` mirrors it as a boolean
  // for cheaper checks on hot paths.
  acceptedAdminRulesAt DateTime?
  // Boolean mirror of `acceptedAdminRulesAt`. We persist both so the
  // staff layout can do a single boolean read on every request without
  // serializing a Date, and so existing master-admin rows (which may have
  // a non-null `acceptedAdminRulesAt` from older code) still satisfy the
  // gate. Set true on successful onboarding submit. The seed script
  // pre-flips this for master admins so they bypass onboarding entirely.
  onboardingCompleted  Boolean            @default(false)
  // Invite flow. `inviteToken` is a single-use random token; the invitee
  // visits /admin/onboarding?token=… to complete signup before it expires.
  inviteToken          String?            @unique
  inviteExpiresAt      DateTime?
  // Recovery email addresses for the master admin only. Used by the
  // password-reset flow as alternate destinations. Regular admins cannot
  // edit this list — enforced at the API layer.
  recoveryEmails       String[]           @default([])
  // Set when the master admin disables / suspends / removes this account.
  // Drives the team detail UI and is included in the audit log metadata.
  removalReason        AdminRemovalReason?
  removalNote          String?            @db.Text
  // Force-logout timestamp. The auth JWT callback compares this against
  // each token's `iat`; tokens issued before this timestamp are treated as
  // signed out on the next request. Bumped automatically when an admin
  // is disabled / suspended / removed and on demand via the master's
  // "Force logout" button.
  sessionsRevokedAt    DateTime?
  // Per-admin email notification preferences. Read by
  // src/lib/email/recipients.ts; structure is a JSON map of category →
  // boolean (e.g. `{ verifications: true, connections: false }`). When
  // null, the recipient is treated as opted-in to every category — that's
  // the default so a freshly-promoted admin starts seeing alerts. Master
  // admins ignore this field; they always receive every notification.
  notificationPreferences Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts             Account[]
  sessions             Session[]
  reviews              Review[]
  helpfulVotes         HelpfulVote[]
  reports              Report[]           @relation("Reporter")
  favorites            Favorite[]
  verificationRequests VerificationRequest[]
  emailCodes           EmailVerificationCode[]
  subscription         Subscription?
  athleteConnections   AthleteProgramConnection[]
  studentConnections   StudentUniversityConnection[]

  // Groups
  groupMemberships     GroupMembership[]
  groupsCreated        Group[]            @relation("GroupCreator")
  groupPosts           GroupPost[]
  groupComments        GroupComment[]
  postVotes            GroupPostVote[]
  commentVotes         GroupCommentVote[]

  // Audit log entries this user authored (admin actions).
  adminActions         AdminActionLog[]

  // Cached community trust score — sum of received upvotes minus a
  // small report penalty, refreshed on vote / report events. We cache
  // because computing on demand would require summing every vote on
  // every page render.
  trustScore           Int                @default(0)

  // In-app notifications targeted at this user (recipient).
  notifications        Notification[]     @relation("NotificationRecipient")
  // Notifications this user triggered (actor — they upvoted, replied, etc.).
  notificationsSent    Notification[]     @relation("NotificationActor")

  @@index([role])
  @@index([subscriptionStatus])
  @@index([verificationStatus])
  @@index([adminStatus])
  @@index([trustScore])
  // Lifecycle filters: "current athletes only", "alumni only", "former
  // players of coach X". Composite with role to keep the alumni-leaderboard
  // and search-filter queries on the index.
  @@index([isAlumni])
  @@index([role, isAlumni])
  @@index([formerUniversityId])
  @@index([formerProgramId])
}

// ---------------------------------------------------------------------------
// Notifications (in-app)
// ---------------------------------------------------------------------------
//
// Append-only-ish log of notifications routed to a single user. The
// `data` JSON carries per-type payload (post id, vote count, mod action
// label, group slug, etc.) — keeps the schema flexible without one
// nullable column per use case. Read state is a simple boolean +
// timestamp. We never delete rows; old notifications fall off the
// /notifications page list naturally.
model Notification {
  id          String           @id @default(cuid())
  userId      String           // recipient
  actorId     String?          // who triggered the notification (nullable for system events)
  type        NotificationType
  // Polymorphic target — `subjectType` is the model name, `subjectId`
  // its primary key. Nullable so admin-action notifications without a
  // single concrete target still fit.
  subjectType String?
  subjectId   String?
  // Free-form payload — title, group slug, vote delta, etc.
  data        Json?
  read        Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

// Append-only log of every admin action. Drives /admin/settings → activity
// view and is the authoritative record for "who did what, when."
//
// Never UPDATE or DELETE rows here in application code. Schema doesn't
// enforce that (Prisma can't), but the API routes only ever INSERT.
model AdminActionLog {
  id          String   @id @default(cuid())
  // The admin who performed the action. Optional only because hard-deleting
  // an admin would otherwise cascade-orphan history; in practice we
  // soft-disable instead so this stays populated.
  actorUserId String?
  // Free-form action key — see src/lib/audit-log.ts for the list of
  // canonical strings used by callers. Not an enum so we can add new
  // actions without a migration.
  action      String
  // What kind of row was touched (User, VerificationRequest,
  // AthleteProgramConnection, etc.). Always paired with `targetId`.
  targetType  String?
  targetId    String?
  // Anything the action wants to capture (before/after diffs, reason,
  // bucketed status, etc.). Free-form JSON.
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Stripe / billing
// ---------------------------------------------------------------------------

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  interval             BillingInterval    @default(MONTHLY)
  status               SubscriptionStatus @default(FREE)
  // Role the user picked at checkout — copied through Stripe metadata so
  // the webhook can hydrate User.role on activation without depending on
  // a fragile in-memory state.
  selectedRole         UserRole?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Schools / Programs / Coaches / Universities / Dorms
// ---------------------------------------------------------------------------

model School {
  id              String    @id @default(cuid())
  universityId    String
  sport           String
  division        Division  @default(D1)
  conference      String?
  description     String?

  // Public-data source tracking
  athleticsUrl    String?
  sourceUrl       String?
  sourceName      String?
  seasonYear      String?
  lastVerifiedAt  DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  coaches    Coach[]
  reviews    Review[]
  favorites  Favorite[]
  groups     Group[]
  athleteConnections AthleteProgramConnection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, sport])
  @@index([sport])
  @@index([division])
}

model Coach {
  id        String   @id @default(cuid())
  name      String
  // URL-friendly identifier from the official roster (optional). Keep as a
  // free string today; future work may add `@@unique([schoolId, slug])` once
  // every record is back-filled.
  slug      String?
  // The role/title of the coach — "Head Coach", "Offensive Coordinator",
  // "Quarterbacks Coach", etc. Stored as the existing `title` column for
  // backwards compatibility with all existing UI. CSV column header is `role`.
  title     String?
  // Optional gender hint for sports that have men's + women's teams.
  // Sport already encodes this in the canonical taxonomy (e.g. "Men's Soccer"),
  // but storing it explicitly makes filtering + display cleaner.
  gender    String?
  schoolId  String
  bio       String?
  imageUrl  String?

  // Public-data source tracking
  // - sourceUrl: official staff page URL (e.g. /sports/baseball/coaches)
  // - officialProfileUrl: direct link to this coach's profile on that staff page
  sourceUrl          String?
  officialProfileUrl String?
  sourceName         String?
  seasonYear         String?
  lastVerifiedAt     DateTime?

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  reviews   Review[]
  favorites Favorite[]
  // Back-relation for COACH-typed Group rows. SetNull on the Group side
  // keeps a coach group around as an "ex-coach" archive if the Coach row
  // is ever deleted; nothing in app code actually deletes coaches today.
  groups    Group[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([name])
}

model University {
  id               String    @id @default(cuid())
  name             String    @unique
  // URL-friendly identifier (lowercase, dash-separated). Optional today; once
  // every row is back-filled this can become required + indexed for routing.
  slug             String?   @unique
  city             String?
  state            String?
  country          String?   @default("USA")
  description      String?
  imageUrl         String?
  // Primary level + conference for the institution. Per-program (per-sport)
  // levels still live on School and override these for sport-specific UI.
  level            Division?
  conference       String?
  // Three distinct URLs (all optional, all official-source-only):
  //   websiteUrl       = main university homepage (.edu)
  //   athleticsWebsite = official athletics site (e.g. gostanford.com)
  //   housingUrl       = official Housing / Residence Life landing page.
  //                      Populated by the dorm-coverage workflow
  //                      (scripts/export-missing-dorms.ts) so researchers
  //                      have a known starting point per university.
  //                      Per-dorm pages still live on Dorm.officialPageUrl.
  websiteUrl       String?
  athleticsWebsite String?
  housingUrl       String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  schools     School[]
  dorms       Dorm[]
  diningHalls Dining[]
  facilities  Facility[]
  reviews     Review[]
  favorites   Favorite[]
  groups      Group[]
  athleteConnections AthleteProgramConnection[]
  studentConnections StudentUniversityConnection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
  @@index([level])
}

model Dorm {
  id           String   @id @default(cuid())
  name         String
  // URL-friendly identifier within the university (lowercase, dash-separated).
  slug         String?
  universityId String
  // Cached city/state from the host university — keeps dorm lists usable
  // without an extra join in heavy list views.
  city         String?
  state        String?
  description  String?
  imageUrl     String?
  // Controlled vocabularies enforced by the importer:
  //   roomType     ∈ {Single, Double, Suite, Apartment}
  //   bathroomType ∈ {Private, Shared, Communal}
  // Stored as String? so unknown / blank rows don't constrain the schema.
  roomType        String?
  bathroomType    String?
  yearBuilt       Int?
  capacity        Int?
  officialPageUrl String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  reviews    Review[]
  favorites  Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, name])
  @@unique([universityId, slug])
}

// Public dining locations on campus (factual directory data only).
model Dining {
  id           String   @id @default(cuid())
  name         String
  universityId String
  location     String?
  hours        String?
  description  String?
  imageUrl     String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, name])
}

// Public athletic facilities (stadiums, weight rooms, training centers, etc.).
model Facility {
  id           String   @id @default(cuid())
  name         String
  universityId String
  // Optional sport tag — if set, must match an allowed Sport in src/lib/sports.ts.
  sport        String?
  facilityType String?  // e.g. "Stadium", "Practice Facility", "Weight Room"
  description  String?
  imageUrl     String?

  // Public-data source tracking
  sourceUrl      String?
  sourceName     String?
  seasonYear     String?
  lastVerifiedAt DateTime?

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([universityId, name])
  @@index([sport])
}

// ---------------------------------------------------------------------------
// Reviews / Ratings
// ---------------------------------------------------------------------------

model Review {
  id           String       @id @default(cuid())
  authorId     String
  reviewType   ReviewType
  status       ReviewStatus @default(PUBLISHED)

  coachId      String?
  schoolId     String?
  universityId String?
  dormId       String?

  title        String?
  body         String       @db.Text

  ratings      Json
  overall      Float

  // pre-computed weight at submission time
  // (Athlete=2.0, Parent=1.25, Student=1.25)
  weight       Float        @default(1.0)

  helpfulCount Int          @default(0)
  reportCount  Int          @default(0)

  // Per-review anonymity opt-in. Defaults to true so existing rows and
  // new submissions stay anonymous unless the author explicitly opts out.
  isAnonymous  Boolean      @default(true)

  // ---------- Trust + risk scoring (set at submit time) ----------
  // Set by src/lib/review-risk.ts. Both 0..100. `trustScore` is the
  // *author* signal at submit time (verified, has connection, mature
  // account, etc.); `riskScore` is the per-submission signal that
  // gates moderationStatus. `credibilityReason` stores the rule-by-rule
  // breakdown so admins can see exactly why a review was flagged
  // without re-running the scorer.
  trustScore           Int                    @default(50)
  riskScore            Int                    @default(0)
  credibilityReason    Json?
  // Default PUBLISHED preserves the historical behavior for any code
  // path that creates a Review row outside the risk-scored API.
  moderationStatus     ReviewModerationStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  coach        Coach?       @relation(fields: [coachId], references: [id], onDelete: Cascade)
  school       School?      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  university   University?  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  dorm         Dorm?        @relation(fields: [dormId], references: [id], onDelete: Cascade)

  helpfulVotes HelpfulVote[]
  reports      Report[]

  @@index([reviewType, status, createdAt])
  @@index([coachId])
  @@index([schoolId])
  @@index([universityId])
  @@index([dormId])
  @@index([authorId])
  // Powers the /admin/reviews moderation queue (PENDING_REVIEW +
  // FLAGGED sorted by risk score desc → most-suspicious first).
  @@index([moderationStatus, riskScore])
}

model Rating {
  id         String     @id @default(cuid())
  reviewType ReviewType
  targetId   String
  category   String
  avg        Float
  count      Int

  updatedAt DateTime @updatedAt

  @@unique([reviewType, targetId, category])
  @@index([targetId])
}

model HelpfulVote {
  id       String @id @default(cuid())
  userId   String
  reviewId String

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
}

model Favorite {
  id           String      @id @default(cuid())
  userId       String
  coachId      String?
  schoolId     String?
  universityId String?
  dormId       String?

  createdAt DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coach      Coach?      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  school     School?     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id], onDelete: Cascade)
  dorm       Dorm?       @relation(fields: [dormId], references: [id], onDelete: Cascade)

  @@unique([userId, coachId])
  @@unique([userId, schoolId])
  @@unique([userId, universityId])
  @@unique([userId, dormId])
}

// ---------------------------------------------------------------------------
// Trust & safety
// ---------------------------------------------------------------------------

model Report {
  id         String       @id @default(cuid())
  reporterId String
  reviewId   String?
  postId     String?
  commentId  String?
  reason     String
  details    String?      @db.Text
  status     ReportStatus @default(OPEN)

  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  reporter User           @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  review   Review?        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  post     GroupPost?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment  GroupComment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reviewId])
  @@index([postId])
}

model VerificationRequest {
  id              String              @id @default(cuid())
  userId          String
  // Which role this verification is targeting — copied off the user at submit
  // time so admins know what to validate against, even if the user's role is
  // somehow changed later.
  targetRole      UserRole
  method          VerificationMethod
  // For parent flows, this stays true; we keep it for analytics/back-compat.
  isParentRequest Boolean             @default(false)
  eduEmail        String?
  rosterUrl       String?
  proofUrl        String?
  // Structured athlete/alumni proof fields. Optional at the schema layer so
  // older rows continue to load; the API enforces required combinations per
  // role at submit time.
  // - sport / universityName: what we're verifying against
  // - studentIdUrl: link to a hosted image of the student ID (or alumni ID)
  // - rosterScreenshotUrl: optional supporting screenshot — never sufficient
  //   on its own per the verification copy
  // - gradYear / playingYears: alumni-only context for admin review
  sport           String?
  universityName  String?
  // Structured selector output. When the user picks a real University /
  // School row from the shared combobox these get populated so admin
  // tooling (and the recruit-→-athlete upgrade auto-create) can skip the
  // fragile name fuzzy-match step. `universityName` / `sport` stay as
  // the display strings + fallback for legacy rows and free-form entry.
  universityId    String?
  schoolId        String?
  studentIdUrl    String?
  rosterScreenshotUrl String?
  gradYear        Int?
  playingYears    String?
  // External profile cross-checks. None are required, all are surfaced in
  // the admin scorecard so a reviewer can spot-check identity across
  // independent sources without leaving the admin page.
  linkedinUrl         String?
  hudlUrl             String?
  recruitingProfileUrl String?  // 247, On3, NCSA, MaxPreps — single canonical
  schoolDirectoryUrl  String?
  // Auto-computed at submit time. Persisted so admins can re-sort the
  // queue without re-running the scorer. Drives the admin checklist UI
  // (src/components/admin/VerificationScorecard.tsx).
  confidenceScore Int?
  // True when a school-email code-verification round-trip completed for
  // this user/email combo before the request was submitted, or when the
  // request itself uses the EDU_EMAIL method and the code was confirmed.
  schoolEmailVerified Boolean @default(false)
  notes           String?             @db.Text
  status          VerificationRequestStatus  @default(PENDING)

  reviewedAt DateTime?
  reviewedBy String?
  // Optional admin-supplied reason shown back to the user on rejection.
  // Free-text, not user-edited.
  rejectionReason String? @db.Text

  // Anti-fake counter — bumped on each retry by this same user.
  attemptNumber  Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId])
}

// One-time email codes used by the student/parent verification flows.
model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  purpose   String   // e.g. "STUDENT_EDU", "PARENT_EMAIL"
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
}

// Athlete ↔ Program connection. Drives every per-target review permission
// check (see src/lib/connection-permissions.ts).
//
// Examples:
//   - User X is the current shortstop at Texas A&M Baseball
//     → CURRENT_ATHLETE, schoolId = <TAMU Baseball School row>
//   - User Y graduated from Florida Football in 2021
//     → ATHLETE_ALUMNI, schoolId = <UF Football>, endYear = 2021
//   - User Z was recruited by LSU Softball but committed to Alabama
//     → RECRUITED_BY for LSU + COMMITTED for Alabama (two rows)
//
// Connection rows default to PENDING and require admin approval before they
// unlock review submission. Admins can approve, reject, and edit them.
//
// `schoolId` is optional only because some early connections may be captured
// before the program/School row exists in our DB — such requests should be
// rejected by admins until a real program is linked. Production code should
// always supply both `universityId` AND `schoolId` together.
model AthleteProgramConnection {
  id              String                  @id @default(cuid())
  userId          String
  universityId    String
  schoolId        String?
  sport           String
  connectionType  AthleteConnectionType
  status          AthleteConnectionStatus @default(PENDING)

  // Optional supporting evidence — admin reviews these manually.
  rosterUrl           String?
  recruitingProofUrl  String?
  notes               String? @db.Text

  startYear       Int?
  endYear         Int?

  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  university  University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  school      School?     @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  // We only allow one connection of a given type per (user, university, sport)
  // — re-submitting a duplicate is a "patch the existing row" workflow, not
  // a "create another row" workflow.
  @@unique([userId, universityId, sport, connectionType])
  @@index([userId, status])
  @@index([universityId, status])
  @@index([schoolId, status])
  @@index([status, createdAt])
}

// Student ↔ University connection. Mirrors AthleteProgramConnection but at
// the university level — students don't connect to a specific sport program.
// CURRENT_STUDENT and STUDENT_ALUMNI unlock UNIVERSITY/DORM reviews;
// ADMITTED_TO and VISITED_CAMPUS unlock ADMISSIONS reviews only.
//
// Default status is PENDING — admin approval is required before any review
// permission unlocks.
model StudentUniversityConnection {
  id              String                  @id @default(cuid())
  userId          String
  universityId    String
  connectionType  StudentConnectionType
  status          StudentConnectionStatus @default(PENDING)

  // Optional supporting evidence — admins review manually.
  schoolEmail     String?
  studentIdUrl    String?
  proofUrl        String?
  notes           String? @db.Text

  startYear       Int?
  endYear         Int?

  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  university  University  @relation(fields: [universityId], references: [id], onDelete: Cascade)

  // One row per (user, university, connectionType) — re-submitting an
  // existing combo patches it instead of creating a duplicate.
  @@unique([userId, universityId, connectionType])
  @@index([userId, status])
  @@index([universityId, status])
  @@index([status, createdAt])
}

// ---------------------------------------------------------------------------
// Verified Groups (Reddit-style, audience-segmented)
// ---------------------------------------------------------------------------

model Group {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  description  String?    @db.Text
  // Either an audience type (legacy) or an entity type (UNIVERSITY /
  // PROGRAM / COACH / PARENT / RECRUITING). See GroupType for the split.
  groupType    GroupType
  // Optional ties to a university / sport / school / coach. Entity-typed
  // groups should always populate the matching FK so the landing page
  // can group + link them. Legacy audience-typed rows may have all null.
  universityId String?
  schoolId     String?
  coachId      String?
  sport        String?
  // Legacy boolean; new code reads `visibility` instead. Kept so older
  // rows that set isPrivate=true still surface as PRIVATE-equivalent on
  // permission checks.
  isPrivate    Boolean    @default(false)
  visibility   GroupVisibility @default(PUBLIC)
  // Splits "who can view" from "who can post" — see GroupAccessMode.
  // New rows should set this; legacy rows fall back to a derived value
  // computed from `visibility` in src/lib/groups-permissions.ts.
  accessMode   GroupAccessMode @default(PUBLIC_VIEW_PUBLIC_POST)
  // Lifecycle gate, orthogonal to accessMode. See LifecycleAudience enum.
  // Default keeps every legacy group inclusive (current + alumni). Owners
  // opt into CURRENT_ONLY (active-roster rooms) or ALUMNI_ONLY (mentorship,
  // transfer portal alumni) via the create / edit UI.
  lifecycleAudience LifecycleAudience @default(CURRENT_AND_ALUMNI)
  // Free-form group rules surfaced in the sidebar. Markdown-ish text;
  // we render it as plain text plus newlines for safety.
  rules        String?    @db.Text
  // Cached counters refreshed on membership / post create-delete (and
  // by the seed script on initial backfill). Counts are also recomputable
  // from `_count` if these ever drift; UI should prefer cached values
  // for landing-page lists, `_count` for the detail page.
  memberCount  Int        @default(0)
  postCount    Int        @default(0)

  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  creator      User             @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  university   University?      @relation(fields: [universityId], references: [id], onDelete: SetNull)
  school       School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  coach        Coach?           @relation(fields: [coachId], references: [id], onDelete: SetNull)
  members      GroupMembership[]
  posts        GroupPost[]

  @@index([groupType])
  @@index([universityId])
  @@index([schoolId])
  @@index([coachId])
  @@index([sport])
  @@index([visibility])
  @@index([lifecycleAudience])
}

model GroupMembership {
  id       String              @id @default(cuid())
  userId   String
  groupId  String
  // Legacy boolean — true = group creator. Keep for back-compat reads;
  // new code should branch on `role`.
  isAdmin  Boolean             @default(false)
  role     GroupMembershipRole @default(MEMBER)

  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([groupId, role])
}

model GroupPost {
  id            String     @id @default(cuid())
  groupId       String
  authorId      String
  title         String
  body          String     @db.Text
  status        PostStatus @default(PUBLISHED)
  // Moderator-set flags:
  //   isPinned/pinnedAt — surface above the regular feed; broken out as
  //                       both a flag and a timestamp so tied pins sort
  //                       by recency.
  //   lockedAt          — when set, new comments are rejected at the
  //                       comment-create endpoint; existing comments
  //                       stay readable.
  isPinned      Boolean    @default(false)
  pinnedAt      DateTime?
  lockedAt      DateTime?
  // Stored as a Postgres enum array — a single post may carry several
  // tags (recruiting + transfer-portal). Empty array = untagged.
  tags          GroupPostTag[] @default([])
  // External media URLs (images / video links). MVP avoids first-party
  // hosting — users paste a public URL the post detail page renders.
  mediaUrls     String[]   @default([])

  upvoteCount   Int        @default(0)
  downvoteCount Int        @default(0)
  totalScore    Int        @default(0)
  commentCount  Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group    Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes    GroupPostVote[]
  comments GroupComment[]
  reports  Report[]

  @@index([groupId, createdAt])
  @@index([groupId, totalScore])
  @@index([groupId, isPinned, totalScore])
  @@index([authorId])
}

model GroupComment {
  id       String     @id @default(cuid())
  postId   String
  authorId String
  parentId String?
  body     String     @db.Text
  status   PostStatus @default(PUBLISHED)

  upvoteCount   Int @default(0)
  downvoteCount Int @default(0)
  totalScore    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    GroupPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  GroupComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies GroupComment[]     @relation("CommentReplies")
  votes   GroupCommentVote[]
  reports Report[]

  @@index([postId, createdAt])
  @@index([parentId])
}

model GroupPostVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  value     Int      // +1 or -1
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

model GroupCommentVote {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comment GroupComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

// ---------------------------------------------------------------------------
// Program / School Requests
//
// Athletes (or anyone) can submit a request when their school or program is
// missing from the database. Admins triage them; approved requests become
// the input for a future seed/import. We intentionally keep this model
// lightweight — no FK to University because the whole point is the school
// may not exist yet.
// ---------------------------------------------------------------------------

model ProgramRequest {
  id            String        @id @default(cuid())
  schoolName    String
  sport         String
  division      String?
  conference    String?
  state         String?
  level         String?

  // Free-text role tag from the requester (e.g. "Athlete", "Parent",
  // "HS Coach"). Not joined to UserRole — anonymous submissions are allowed.
  requesterRole  String?
  requesterEmail String?

  // Helpful pointers for the admin doing the import:
  rosterUrl     String?
  athleticsUrl  String?
  notes         String?       @db.Text

  status        RequestStatus @default(PENDING)
  // Manual ranking knob admins can use to surface high-signal requests.
  priorityScore Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([schoolName])
  @@index([sport])
}
